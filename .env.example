# LLM Backend (OpenAI-compatible API)
# Default: local Ollama
LLM_BASE_URL=http://localhost:11434/v1/chat/completions
LLM_MODEL=qwen2.5:7b

# Alternative: OpenAI
# LLM_BASE_URL=https://api.openai.com/v1/chat/completions
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...

# Alternative: Anthropic (via OpenAI-compatible proxy)
# LLM_BASE_URL=http://localhost:8080/v1/chat/completions
# LLM_MODEL=claude-sonnet-4-20250514

# Embedding (local only, no API key needed)
# Set to remote URL if running on a separate machine
# EMBED_REMOTE_URL=http://192.168.1.100:8790/embed

# Server
SERVE_PORT=8780
